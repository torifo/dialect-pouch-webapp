# dialect-pocket 本番 .env の例。これをコピーして .env を作る(.env は commit しない)。
#   cp .env.example .env  &&  値を埋める

# 公開ドメイン(VPS: VIRTUAL_HOST / LETSENCRYPT_HOST / PHX_HOST に使われる)
APP_HOST=dialect-pocket.riumu.net

# PostgreSQL の postgres ユーザーのパスワード
POSTGRES_PASSWORD=change-me

# Phoenix の署名キー。生成: mix phx.gen.secret
SECRET_KEY_BASE=change-me-to-a-64+-char-secret

# 使用する GHCR イメージタグ(既定 latest。再現性重視なら git SHA を指定)
IMAGE_TAG=latest

# 任意
# PORT=4000
# POOL_SIZE=10
